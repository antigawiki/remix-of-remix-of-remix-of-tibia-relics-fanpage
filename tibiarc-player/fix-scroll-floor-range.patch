--- a/lib/parser.cpp
+++ b/lib/parser.cpp

# =============================================
# TibiaRelic Protocol Patches — Scroll + FloorUp
# Applied via tibiarc-player/scroll_floor_patch.py
# =============================================

# --- Scroll Opcodes (0x65-0x68) ---
# TibiaRelic sends a full 18x14 multi-floor map description for every
# scroll opcode, not the standard 1-row or 1-column strip.
# All four directions use offset (-8, -6) and full TileBufferWidth x TileBufferHeight.

# ParseMoveNorth:  (-8, -6, W, 1)  → (-8, -6, W, H)
# ParseMoveEast:   (+9, -6, 1, H)  → (-8, -6, W, H)
# ParseMoveSouth:  (-8, +7, W, 1)  → (-8, -6, W, H)
# ParseMoveWest:   (-8, -6, 1, H)  → (-8, -6, W, H)

# --- FloorUp (0xBE) at z==7 ---
# When transitioning from underground (z>7) to surface (z==7),
# TibiaRelic sends only 1 floor (z=5) instead of the standard 6 floors.
# The patch wraps the existing 6-floor loop with a condition:
#   if (Position_.Z == 7) → read only floor z=5
#   else → original 6-floor loop (zIdx 5→0)
